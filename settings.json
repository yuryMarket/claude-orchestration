{
  "permissions": {
    "allow": [
      "WebSearch",
      "Read(~/.claude/**)",
      "Edit(~/.claude/**)",
      "Write(~/.claude/**)",
      "Read(//Users/yury_shubianok/.claude/**)",
      "Edit(//Users/yury_shubianok/.claude/**)",
      "Write(//Users/yury_shubianok/.claude/**)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/yury_shubianok/.claude/hooks/gate-workflow.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/yury_shubianok/.claude/hooks/session-start.sh"
          },
          {
            "type": "command",
            "command": "/Users/yury_shubianok/.claude/hooks/session-start-pending.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/yury_shubianok/.claude/hooks/detect-correction.sh",
            "timeout": 60,
            "statusMessage": "Анализирую паттерны коррекций..."
          }
        ]
      }
    ]
  },
  "model": "sonnet"
}
